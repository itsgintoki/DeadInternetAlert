NODE_ENV=development
PORT=8000
TRUST_PROXY=false
ALLOWED_ORIGINS=http://localhost:3000

POSTGRES_USER=app
POSTGRES_PASSWORD=replace-with-a-long-unique-password
POSTGRES_DB=deadinternetalert
DATABASE_URL=postgresql://app:replace-with-a-long-unique-password@localhost:5432/deadinternetalert

REDIS_PASSWORD=replace-with-a-long-unique-password
